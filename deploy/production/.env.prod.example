ECHOIM_DOMAIN=echoim.wandcheers.xyz
ECHOIM_ADMIN_PATH=/admin/

MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=echoim
MYSQL_USERNAME=echoim
MYSQL_PASSWORD=replace-with-mysql-password

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

SERVER_PORT=8080
ECHOIM_IM_PORT=8091
ECHOIM_JWT_SECRET=replace-with-random-secret
SPRING_PROFILES_ACTIVE=prod

BACKEND_IMAGE=ghcr.io/your-github-owner/echoim-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-owner/echoim-frontend:latest

SPRING_MAIL_HOST=smtp.qq.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-qq@qq.com
SPRING_MAIL_PASSWORD=replace-with-qq-smtp-authorization-code
SPRING_MAIL_FROM=EchoIM <your-qq@qq.com>

ECHOIM_FILE_STORAGE_TYPE=oss
ECHOIM_FILE_MAX_SIZE=104857600
ECHOIM_FILE_SIGNED_URL_EXPIRE_SECONDS=600

ALIYUN_OSS_BUCKET=echoim
ALIYUN_OSS_ACCESS_KEY_ID=replace-with-oss-ak
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-with-oss-sk
ECHOIM_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

ECHOIM_CALL_ICE_SERVERS=
