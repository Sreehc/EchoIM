MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=echoim
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

SERVER_PORT=8080
ECHOIM_IM_PORT=8091
ECHOIM_JWT_SECRET=replace-with-your-jwt-secret
SPRING_PROFILES_ACTIVE=prod
BACKEND_IMAGE=ghcr.io/your-github-owner/echoim-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-owner/echoim-frontend:latest
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=mailer@example.com
SPRING_MAIL_PASSWORD=replace-with-your-mail-password
SPRING_MAIL_FROM=EchoIM <mailer@example.com>
ECHOIM_ADMIN_SUPER_USERNAME=
ECHOIM_ADMIN_SUPER_PASSWORD=
ECHOIM_ADMIN_SUPER_NICKNAME=系统管理员

ECHOIM_FILE_STORAGE_TYPE=oss
ECHOIM_FILE_MAX_SIZE=104857600
ECHOIM_FILE_SIGNED_URL_EXPIRE_SECONDS=600
ECHOIM_FILE_ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/gif,image/webp
ECHOIM_FILE_ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
ECHOIM_FILE_ALLOWED_FILE_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/plain,application/zip,application/x-zip-compressed
ECHOIM_FILE_ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,zip

ALIYUN_OSS_BUCKET=your-bucket-name
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ECHOIM_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
