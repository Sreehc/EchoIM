hover,\n.theme-toggle[data-v-45f5edd7]:focus-visible {\n  border-color: var(--color-shell-border-strong);\n  background: var(--color-shell-action-hover);\n  color: var(--color-text-1);\n}\n.login-card__intro[data-v-45f5edd7] {\n  display: grid;\n  align-content: space-between;\n  gap: 18px;\n  padding: 10px 4px 10px 4px;\n}\n.login-card__eyebrow[data-v-45f5edd7] {\n  display: inline-block;\n  color: var(--color-shell-eyebrow);\n  font: 700 0.74rem/1 var(--font-body);\n  letter-spacing: 0.08em;\n}\n.login-card__intro h1[data-v-45f5edd7] {\n  max-width: 11ch;\n  font: var(--font-title-lg);\n  letter-spacing: -0.05em;\n}\n.login-card__intro p[data-v-45f5edd7],\n.login-card__meta[data-v-45f5edd7] {\n  color: var(--color-text-2);\n  font-size: 0.92rem;\n  line-height: 1.6;\n}\n.login-card__highlights[data-v-45f5edd7] {\n  display: grid;\n  gap: 10px;\n}\n.login-card__highlights article[data-v-45f5edd7] {\n  padding: 14px 16px;\n  border: 1px solid var(--color-shell-border);\n  border-radius: 18px;\n  background: color-mix(in srgb, var(--color-shell-card-muted) 92%, transparent);\n}\n.login-card__highlights strong[data-v-45f5edd7] {\n  display: block;\n  margin-bottom: 6px;\n  font: var(--font-title-sm);\n}\n.login-card__highlights p[data-v-45f5edd7] {\n  font-size: 0.84rem;\n  line-height: 1.55;\n}\n.login-card__section[data-v-45f5edd7] {\n  padding: 20px;\n  border: 1px solid var(--color-shell-border);\n  border-radius: 24px;\n  background: var(--color-shell-card-strong);\n  box-shadow: var(--shadow-inset-soft);\n}\n.login-card__accounts[data-v-45f5edd7] {\n  display: grid;\n  gap: 10px;\n  margin-bottom: 18px;\n}\n.login-account[data-v-45f5edd7] {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 28px;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 16px;\n  border: 1px solid var(--color-shell-border);\n  border-radius: 18px;\n  background: color-mix(in srgb, var(--color-shell-card-muted) 94%, transparent);\n  text-align: left;\n}\n.login-account__copy 